PORT=3000

REDIS_URL=redis://127.0.0.1:6379
# Optional: REDIS_HOST / REDIS_PORT if you prefer not to use REDIS_URL
# docker-compose in this repo uses external Mongo from this value.
# Example:
# MONGO_URI=mongodb://host.docker.internal:27017/github-analyse
# REDIS_URL=redis://redis:6379

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
APP_BASE_URL=http://localhost:3000
GITHUB_REDIRECT_URI=http://localhost:3000/auth/github/callback
SESSION_SECRET=replace_with_a_long_random_secret
NODE_ENV=development
DEBIAN_MIRROR=deb.debian.org

# Groq (OpenAI-compatible chat completions)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# crawl4ai sidecar mode (default = docker, uses official image)
# CRAWL4AI_MODE=docker
# CRAWL4AI_DOCKER_IMAGE=unclecode/crawl4ai:0.8
# DOCKER_BIN=docker
# Optional local python mode:
# CRAWL4AI_MODE=python
# PYTHON_BIN=python3
# Optional local fallback:
# CRAWL4AI_MODE=python
# PYTHON_BIN=python3
# CRAWL_TIMEOUT_MS=120000
# MAX_CRAWL_URLS=3
# ANALYSIS_WORKER_CONCURRENCY=2
# Retry guard for manual re-analysis endpoint (/api/analysis/retry)
# ANALYSIS_RETRY_MAX_ATTEMPTS=3
# ANALYSIS_RETRY_WINDOW_MS=3600000
